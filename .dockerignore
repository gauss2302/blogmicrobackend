# Applies to the repo-root build contexts (auth/user/post/search/api-gateway).
# Keeps secrets, VCS metadata, and unrelated/large trees out of build layers.
# The Go builds only need ./proto and ./services/<svc>.
**/.env
.git
.gitignore
**/node_modules
frontend
docs
monitoring
scripts
*.md
.idea
.cursor
.claude
.DS_Store
